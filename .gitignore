# Rust / Cargo
/target/
**/*.rs.bk
# Cargo.lock IS committed. The workspace ships prebuilt binaries (PyPI wheels,
# npm addons), so the dependency graph must be pinned for a release to be
# reproducible and auditable — an unlocked graph would re-resolve transitive
# deps on every release build.

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Criterion / profiling
/criterion/
/perf.data*
/flamegraph.svg
*.profraw
*.profdata
/pgo-data/

# Generated / local
/out/
*.log
.env
.env.*
.claude/skills/ticketsplease

# Coding harness
.pi-subagents/

# Python binding: local venv + build output
/crates/interpretthis-python/.venv/
/crates/interpretthis-python/dist/

# Node binding: installed packages + napi build output
/crates/interpretthis-node/node_modules/
/crates/interpretthis-node/*.node
/crates/interpretthis-node/index.js
/crates/interpretthis-node/index.d.ts
/crates/interpretthis-node/npm/
